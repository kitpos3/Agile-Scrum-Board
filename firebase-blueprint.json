{
  "entities": {
    "Sprint": {
      "title": "Sprint",
      "description": "A sprint in the agile process",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the sprint" },
        "goal": { "type": "string", "description": "Goal of the sprint" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "velocityTarget": { "type": "number", "description": "Target story points for the sprint" },
        "ownerId": { "type": "string", "description": "User ID of the creator" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task or story in a sprint",
      "type": "object",
      "properties": {
        "sprintId": { "type": "string", "description": "ID of the sprint this task belongs to" },
        "epic": { "type": "string", "description": "Epic or module name" },
        "desc": { "type": "string", "description": "Task description" },
        "assignee": { "type": "string", "description": "Person assigned to the task" },
        "status": { "type": "string", "enum": ["Backlog", "To Do", "In Progress", "Code Review", "Testing", "Done"] },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "sp": { "type": "number", "description": "Story points" },
        "blockers": { "type": "string", "description": "Any blockers for the task" },
        "ownerId": { "type": "string", "description": "User ID of the creator" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sprintId", "desc", "status", "priority", "sp", "ownerId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a task",
      "type": "object",
      "properties": {
        "taskId": { "type": "string", "description": "ID of the task this comment belongs to" },
        "text": { "type": "string", "description": "Comment content" },
        "authorId": { "type": "string", "description": "User ID of the commenter" },
        "authorName": { "type": "string", "description": "Name of the commenter" },
        "authorPhotoUrl": { "type": "string", "description": "Photo URL of the commenter" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "text", "authorId", "createdAt"]
    },
    "Developer": {
      "title": "Developer",
      "description": "A developer in the team",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the developer" },
        "ownerId": { "type": "string", "description": "User ID of the creator" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/sprints/{sprintId}": {
      "schema": { "$ref": "#/entities/Sprint" },
      "description": "Stores sprint data"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores task data"
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores comments on tasks"
    },
    "/developers/{developerId}": {
      "schema": { "$ref": "#/entities/Developer" },
      "description": "Stores developer data"
    }
  }
}
