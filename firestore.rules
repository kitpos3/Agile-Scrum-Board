rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sprints
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - goal: string (optional, < 500 chars)
    //   - startDate: timestamp (optional)
    //   - endDate: timestamp (optional)
    //   - velocityTarget: number (optional, >= 0)
    //   - ownerId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: tasks
    // Document ID: auto-generated
    // Fields:
    //   - sprintId: string (required, < 100 chars)
    //   - epic: string (optional, < 100 chars)
    //   - desc: string (required, < 1000 chars)
    //   - assignee: string (optional, < 100 chars)
    //   - status: string (required, in ['Backlog', 'To Do', 'In Progress', 'Code Review', 'Testing', 'Done'])
    //   - priority: string (required, in ['High', 'Medium', 'Low'])
    //   - sp: number (required, >= 0)
    //   - blockers: string (optional, < 500 chars)
    //   - ownerId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: comments
    // Document ID: auto-generated
    // Fields:
    //   - taskId: string (required, < 100 chars)
    //   - text: string (required, < 2000 chars)
    //   - authorId: string (required, immutable)
    //   - authorName: string (optional, < 100 chars)
    //   - authorPhotoUrl: string (optional, < 500 chars)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isCommentAuthor() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    function ownerIdUnchanged() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == request.auth.uid;
    }

    function authorIdUnchanged() {
      return !('authorId' in request.resource.data) || request.resource.data.authorId == request.auth.uid;
    }

    function ownerIdNotModified() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == resource.data.ownerId;
    }

    function authorIdNotModified() {
      return !('authorId' in request.resource.data) || request.resource.data.authorId == resource.data.authorId;
    }

    function createdAtNotModified() {
      return !('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function validOptionalStringLength(field, minLen, maxLen) {
      return !(field in request.resource.data) || (
        request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen
      );
    }

    function isPositiveOrZero(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    function isValidOptionalPositiveOrZero(field) {
      return !(field in request.resource.data) || (request.resource.data[field] is number && request.resource.data[field] >= 0);
    }

    function isValidOptionalTimestamp(field) {
      return !(field in request.resource.data) || request.resource.data[field] is timestamp;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidSprint(data) {
      return hasOnlyAllowedFields(['name', 'goal', 'startDate', 'endDate', 'velocityTarget', 'ownerId', 'createdAt']) &&
             hasRequiredFields(['name', 'ownerId', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             validOptionalStringLength('goal', 0, 500) &&
             isValidOptionalTimestamp('startDate') &&
             isValidOptionalTimestamp('endDate') &&
             isValidOptionalPositiveOrZero('velocityTarget') &&
             data.createdAt is timestamp;
    }

    function isValidTask(data) {
      return hasOnlyAllowedFields(['sprintId', 'epic', 'desc', 'assignee', 'status', 'priority', 'sp', 'blockers', 'ownerId', 'createdAt']) &&
             hasRequiredFields(['sprintId', 'desc', 'status', 'priority', 'sp', 'ownerId', 'createdAt']) &&
             validStringLength('sprintId', 1, 100) &&
             validOptionalStringLength('epic', 0, 100) &&
             validStringLength('desc', 1, 1000) &&
             validOptionalStringLength('assignee', 0, 100) &&
             data.status in ['Backlog', 'To Do', 'In Progress', 'Code Review', 'Testing', 'Done'] &&
             data.priority in ['High', 'Medium', 'Low'] &&
             isPositiveOrZero('sp') &&
             validOptionalStringLength('blockers', 0, 500) &&
             data.createdAt is timestamp;
    }

    function isValidComment(data) {
      return hasOnlyAllowedFields(['taskId', 'text', 'authorId', 'authorName', 'authorPhotoUrl', 'createdAt']) &&
             hasRequiredFields(['taskId', 'text', 'authorId', 'createdAt']) &&
             validStringLength('taskId', 1, 100) &&
             validStringLength('text', 1, 500000) &&
             validOptionalStringLength('authorName', 0, 100) &&
             validOptionalStringLength('authorPhotoUrl', 0, 500) &&
             data.createdAt is timestamp;
    }

    function isValidDeveloper(data) {
      return hasOnlyAllowedFields(['name', 'ownerId', 'createdAt']) &&
             hasRequiredFields(['name', 'ownerId', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /sprints/{sprintId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSprint(request.resource.data) && ownerIdUnchanged();
      allow update: if isDocOwner() && isValidSprint(request.resource.data) && ownerIdNotModified() && createdAtNotModified();
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && ownerIdUnchanged();
      allow update: if isDocOwner() && isValidTask(request.resource.data) && ownerIdNotModified() && createdAtNotModified();
      allow delete: if isDocOwner();
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated() && get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && isValidComment(request.resource.data) && authorIdUnchanged();
      allow update: if isCommentAuthor() && isValidComment(request.resource.data) && authorIdNotModified() && createdAtNotModified();
      allow delete: if isCommentAuthor();
    }

    match /developers/{developerId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDeveloper(request.resource.data) && ownerIdUnchanged();
      allow update: if isDocOwner() && isValidDeveloper(request.resource.data) && ownerIdNotModified() && createdAtNotModified();
      allow delete: if isDocOwner();
    }
  }
}
